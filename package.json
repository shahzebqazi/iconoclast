{
  "name": "iconoclast-audio",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:build": "tsx scripts/generate/index.ts",
    "assets:gallery": "ICONOCLAST_DEV_GALLERY=1 tsx scripts/generate/index.ts",
    "verify:public": "node scripts/verifyPublicSite.mjs",
    "assets:clean": "node -e \"import('node:fs/promises').then(fs=>fs.rm('site/public',{recursive:true,force:true}))\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
